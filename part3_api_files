# 2: ERROR HANDLING & LOGGING
print("\n-Starting Exception Handling-")

log_filename = "error_log.txt"

# Clear the log file for this run
with open(log_filename, "w") as f:
    f.write("Error Tracking Log\n-----\n")

def log_issue(error_name, message):
    # Log the error with a quick timestamp
    current_time = datetime.now().strftime("%H:%M:%S")
    with open(log_filename, "a") as f:
        f.write(f"[{current_time}] {error_name}: {message}\n")
    print(f"Logged a {error_name} to the file.")

# Running tests for 4 common errors
try:
    # Test 1: Division by zero
    bad_math = 10 / 0
except ZeroDivisionError as e:
    log_issue("MathError", str(e))

try:
    # Test 2: File doesn't exist
    with open("not_a_real_file.txt", "r") as f:
        data = f.read()
except FileNotFoundError:
    log_issue("FileMissing", "The text file was not found in the folder.")

try:
    # Test 3: String to Int conversion fail
    val = int("python")
except ValueError:
    log_issue("ValueError", "Cannot convert alphabetical text into an integer.")

try:
    # Test 4: Accessing index that isn't there
    nums = [1, 5]
    pick = nums[10]
except IndexError:
    log_issue("IndexError", "The list index is out of bounds.")


# 3: API INTEGRATION
print("\n-Starting API Integration-")

def get_json_data(target_url):
    print(f"Fetching from: {target_url}")
    try:
        # Standard 10s timeout
        response = requests.get(target_url, timeout=10)
        response.raise_for_status() 
        return response.json()
    except Exception as err:
        log_issue("API_Fail", str(err))
        return None

# Get user data first
users = get_json_data("https://jsonplaceholder.typicode.com/users")

if users:
    print(f"Found {len(users)} users. Examples:")
    for u in users[:3]:
        company_nm = u['company']['name']
        city_nm = u['address']['city']
        print(f" * {u['name']} (Company: {company_nm}, City: {city_nm})")

    # Exporting the user list to JSON
    with open("users_data.json", "w") as f:
        json.dump(users, f, indent=2)
    print("\nUsers exported to users_data.json.")

# Get post data next
posts = get_json_data("https://jsonplaceholder.typicode.com/posts")
if posts:
    print(f"\nSuccess: Retrieved {len(posts)} posts.")
    
    # Manual dictionary counting (feels more like student code than .get())
    post_counts = {}
    for p in posts:
        uid = p['userId']
        if uid in post_counts:
            post_counts[uid] += 1
        else:
            post_counts[uid] = 1
    
    print("Posts per user (top 3 IDs):")
    sorted_ids = sorted(post_counts.keys())
    for uid in sorted_ids[:3]:
        print(f" - User {uid}: {post_counts[uid]} posts")

print("\n-Final View of the Error Log-")
